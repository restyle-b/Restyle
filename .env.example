# העתק ל-.env.local ומלא ערכים אמיתיים (ראה docs/SETUP.md).
# ⚠️ לעולם לא לדחוף ערכים אמיתיים ל-git.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=restyle-media

# Brevo (שליחת מיילים)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=                # כתובת מאומתת/דומיין מאומת ב-Brevo, לדוגמה noreply@restyle.co.il
CONTACT_NOTIFICATION_EMAIL=        # לאן מתקבלות הודעות מטופס צור קשר

# Payments (Stage 2, Phase 5) — ראה docs/features/shop.md +
# .claude/skills/tranzila-payments/SKILL.md. "mock" (ברירת מחדל) לא דורש
# כלום. "tranzila" דורש גם TRANZILA_TERMINAL וגם TRANZILA_TERMINAL_PASSWORD
# (אין credentials אמיתיים עדיין — לא לחבר בפועל בלי אישור מפורש).
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=
TRANZILA_TERMINAL=
TRANZILA_TERMINAL_PASSWORD=
