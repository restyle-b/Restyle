// סכמת Prisma ל-Restyle. מורחבת בכל שלב (ראה docs/ARCHITECTURE.md).
// כסף תמיד באגורות (Int). כל טבלה עם נתוני משתמש תקבל RLS ב-Supabase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// משתמש — מסונכרן עם Supabase Auth (id = auth user id).
model User {
  id        String   @id
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  enrollments Enrollment[]

  @@map("users")
}

// הגדרות אתר גלובליות — שורה אחת בלבד (id קבוע = 1). Phase 8.1.
model SiteSettings {
  id            Int      @id @default(1)
  phone         String
  email         String
  address       String
  whatsapp      String
  instagramUrl  String?
  facebookUrl   String?
  appStoreUrl   String?
  googlePlayUrl String?
  updatedAt     DateTime @updatedAt
  updatedById   String?

  @@map("site_settings")
}

// שעות פתיחה — שורה אחת ליום. Phase 8.1.
model OpeningHour {
  id       Int     @id @default(autoincrement())
  dayOrder Int     @unique
  dayHe    String
  dayEn    String?
  dayAr    String?
  hoursHe  String
  hoursEn  String?
  hoursAr  String?

  @@map("opening_hours")
}

// קורסי האקדמיה — מוצג ב-/academy. Phase 8.2.
model Course {
  id            String   @id @default(cuid())
  slug          String   @unique
  order         Int      @default(0)
  nameHe        String
  nameEn        String?
  nameAr        String?
  descriptionHe String   @db.Text
  descriptionEn String?  @db.Text
  descriptionAr String?  @db.Text
  durationHe    String
  durationEn    String?
  durationAr    String?
  levelHe       String
  levelEn       String?
  levelAr       String?
  // מסחר (Phase 7). כל השדות אופציונליים — קורס בלי priceAgorot נשאר תדמיתי
  // (CTA צור-קשר). כסף תמיד Int אגורות.
  priceAgorot    Int? // מחיר מלא; null → לא ניתן לרכישה
  depositPercent Int      @default(20) // 0 = רק תשלום מלא
  capacity       Int? // null = ללא הגבלת מקומות
  detailsHe      String?  @db.Text // הסבר מפורט
  detailsEn      String?  @db.Text
  detailsAr      String?  @db.Text
  syllabusHe     String?  @db.Text // סילבוס (טקסט חופשי)
  syllabusEn     String?  @db.Text
  syllabusAr     String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  enrollments   Enrollment[]

  @@map("courses")
}

// המלצות לקוחות — מוצג בדף הבית. Phase 8.3.
model Testimonial {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  nameHe    String
  nameEn    String?
  nameAr    String?
  // תפקיד/תיאור קצר להצגה "שם · תפקיד" (אופציונלי — לא כל המלצה צריכה אחד).
  roleHe    String?
  roleEn    String?
  roleAr    String?
  quoteHe   String   @db.Text
  quoteEn   String?  @db.Text
  quoteAr   String?  @db.Text
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

// תמונות גלריה — מוצג ב-/gallery ובדף הבית. Phase 8.3.
// ⚠️ imageUrl (לא imageKey/R2): העלאת R2 presigned עדיין לא חוברה (חסרים
// אישורי R2 — ראה docs/SETUP.md §4). כרגע מנהל מדביק כתובת URL ישירה
// (לדוגמה תמונה שהועלתה ידנית/CDN חיצוני). מיגרציה ל-R2 upload — Phase 8.3b עתידי.
model GalleryImage {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  imageUrl  String
  altHe     String
  altEn     String?
  altAr     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

// טקסטי שיווק/משפטי — key-value גמיש (namespace/key תואם למבנה messages/he.json),
// ממוזג ל-messages ב-src/i18n/request.ts כך שכל t()/useTranslations קיים מקבל
// אוטומטית עדכון מה-CMS בלי לשנות קומפוננטות. Phase 8.4.
model ContentBlock {
  id          String   @id @default(cuid())
  namespace   String
  key         String
  valueHe     String   @db.Text
  valueEn     String?  @db.Text
  valueAr     String?  @db.Text
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@unique([namespace, key])
  @@map("content_blocks")
}

// ── חנות (Stage 2, Phase 4+5+6) — ראה docs/features/shop.md ──

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  COMPLETED
  CANCELLED
  FAILED

  @@map("order_status")
}

enum DeliveryMethod {
  PICKUP
  DELIVERY

  @@map("delivery_method")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_status")
}

// קטגוריית מוצרים — לסינון בקטלוג.
model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  order     Int       @default(0)
  nameHe    String
  nameEn    String?
  nameAr    String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

// מוצרי החנות.
// ⚠️ imageUrl (לא imageKey/R2) — אותה מוסכמה כמו GalleryImage.imageUrl (ראה
// שם למה). imageUrl ריק/null => מוצג ImagePlaceholder בציבורי.
model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  order         Int         @default(0)
  nameHe        String
  nameEn        String?
  nameAr        String?
  descriptionHe String      @db.Text
  descriptionEn String?     @db.Text
  descriptionAr String?     @db.Text
  priceAgorot   Int
  stock         Int         @default(0)
  imageUrl      String?
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orderItems    OrderItem[]

  @@index([categoryId])
  @@map("products")
}

// הזמנה — אורח או משתמש רשום (userId אופציונלי, guest checkout מותר).
model Order {
  id     String @id @default(cuid())
  orderNumber String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  status OrderStatus @default(PENDING)

  // תקציר לקוח — snapshot בזמן ההזמנה, לא תלוי בפרופיל עתידי.
  customerName  String
  customerEmail String
  customerPhone String

  deliveryMethod DeliveryMethod
  shippingAgorot Int            @default(0) // 0=pickup, 4000=delivery (קבוע כרגע)
  addressLine    String?
  addressCity    String?
  addressNotes   String?

  subtotalAgorot Int // סכום פריטים בלבד, מחושב בשרת
  totalAgorot    Int // subtotal + shipping, מחושב בשרת

  paymentProvider  String? // "mock" | "tranzila" — נשמר בזמן היצירה
  guestLookupToken String? @unique // אקראי, ל-guest order lookup

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@index([customerEmail])
  @@map("orders")
}

// שורת פריט בהזמנה — snapshot של שם+מחיר בזמן הרכישה (לא JOIN חי ל-Product,
// כך שהזמנה היסטורית לא משתנה אם מחיר/שם מוצר משתנים בעתיד).
model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  nameHeSnapshot  String
  unitPriceAgorot Int
  quantity        Int
  lineTotalAgorot Int

  @@index([orderId])
  @@map("order_items")
}

// תשלום — קשור 1:1 להזמנה. לעולם לא PAN/CVV — רק מזהי התייחסות של הספק.
model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider        String // "mock" | "tranzila"
  status          PaymentStatus @default(PENDING)
  amountAgorot    Int
  externalRef     String? // transactionId/confirmationCode מהספק
  last4           String? // 4 ספרות אחרונות בלבד (אם מוחזר), לתצוגה בלבד
  failureReason   String? // הודעת כשל קריאה-לאדם, בלי פרטי כרטיס
  rawResponseMeta Json? // metadata לא-רגיש בלבד (status code, timestamp) — לעולם לא body מלא

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, externalRef])
  @@map("payments")
}

// ===== Phase 7: רכישת קורסים =====

enum EnrollmentStatus {
  PENDING
  DEPOSIT_PAID
  PAID
  CANCELLED
  FAILED

  @@map("enrollment_status")
}

enum EnrollmentPlan {
  DEPOSIT
  FULL

  @@map("enrollment_plan")
}

enum CoursePaymentKind {
  DEPOSIT
  BALANCE
  FULL

  @@map("course_payment_kind")
}

// הרשמה לקורס — מקבילה ל-Order בחנות אך ייעודית (מקדמה/יתרה, בלי משלוח).
// כסף תמיד Int אגורות; המחיר/מקדמה snapshot בזמן ההרשמה.
model Enrollment {
  id               String @id @default(cuid())
  enrollmentNumber String @unique // "C-XXXXXX", קריא ללקוח

  courseId             String?
  course               Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseNameHeSnapshot String

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  guestLookupToken String? @unique

  customerName  String
  customerEmail String
  customerPhone String

  plan              EnrollmentPlan
  coursePriceAgorot Int // snapshot מחיר מלא
  depositAgorot     Int // snapshot מקדמה מחושבת
  amountPaidAgorot  Int              @default(0) // סכום ששולם מצטבר
  status            EnrollmentStatus @default(PENDING)
  paymentProvider   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments CoursePayment[]

  @@index([userId])
  @@index([customerEmail])
  @@index([courseId])
  @@map("enrollments")
}

// תשלום קורס — רבים-ל-אחד להרשמה (מקדמה + יתרה). לעולם לא PAN/CVV.
model CoursePayment {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  kind            CoursePaymentKind
  provider        String
  status          PaymentStatus     @default(PENDING)
  amountAgorot    Int // הסכום הספציפי של העסקה הזו (מקדמה/מלא/יתרה)
  externalRef     String?
  last4           String?
  failureReason   String?
  rawResponseMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enrollmentId])
  @@index([provider, externalRef])
  @@map("course_payments")
}
